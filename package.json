{
  "name": "swole-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run tokens:build && node scripts/generate-convex-config.js && next build",
    "build:tokens": "node scripts/build-tokens.js",
    "check": "bun run lint && bun run typecheck",
    "dev": "bun run tokens:build && (infisical run -- npx convex dev & (lsof -ti:3000 | xargs kill -9 2>/dev/null || true; infisical run -- next dev --turbo))",
    "dev:convex": "npx convex dev",
    "dev:next": "infisical run -- next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "bun run tokens:build && next build && next start",
    "start": "next start",
    "tokens:build": "node scripts/build-tokens.js",
    "tokens:watch": "node scripts/build-tokens.js --watch",
    "typecheck": "tsc --noEmit",
    "test": "npx vitest",
    "test:ci": "npx vitest run --coverage",
    "test:watch": "npx vitest",
    "coverage": "npx vitest run --coverage",
    "e2e": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.22",
    "@ai-sdk/openai": "^1.3.24",
    "@ai-sdk/provider-utils": "^2.2.8",
    "@convex-dev/workos": "^0.0.1",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/query-sync-storage-persister": "^5.83.1",
    "@tanstack/react-query": "^5.84.2",
    "@tanstack/react-query-persist-client": "^5.84.2",
    "@workos-inc/authkit-nextjs": "^2.5.0",
    "ai": "5.0.0-beta.29",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.26.2",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.536.0",
    "next": "^15.4.6",
    "oauth4webapi": "^3.6.2",
    "posthog-js": "^1.259.0",
    "posthog-node": "^5.6.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.62.0",
    "recharts": "^3.1.2",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.33.0",
    "eslint-config-next": "^15.4.6",
    "eslint-plugin-drizzle": "^0.2.3",
    "happy-dom": "^18.0.1",
    "jsdom": "^26.1.0",
    "msw": "^2.10.4",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1",
    "vitest": "^3.2.4"
  },
  "ct3aMetadata": {
    "initVersion": "7.39.3"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "packageManager": "bun@1.1.42",
  "volta": {
    "node": "20.19.4"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
