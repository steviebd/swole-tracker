# Swole Tracker Environment Variables
# This file shows example values for Development, Preview, and Production environments.
# Copy to .env.local for local development. Set Preview/Production in Vercel Project Settings or Infisical.

# Convex Database & API (Environment-driven, no hardcoded convex.json)
# Development: Auto-generated by `npx convex dev` (e.g., dev:unique-porcupine-779)
# Production: Set to your production deployment name (e.g., prod:your-production-deployment)
CONVEX_DEPLOYMENT=dev:your-development-deployment-name
# The public URL for your Convex deployment (matches the deployment above)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# WorkOS Authentication
# Development: Use test keys from your WorkOS dashboard
# Production: Use live keys (sk_live_*, client_live_*)
WORKOS_CLIENT_ID=client_your_workos_client_id
WORKOS_API_KEY=sk_test_your_workos_api_key
NEXT_PUBLIC_WORKOS_CLIENT_ID=client_your_workos_client_id
# Development: http://localhost:3000/callback
# Production: https://yourdomain.com/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
# Generate a secure 32-character string for cookie encryption
WORKOS_COOKIE_PASSWORD=your_32_character_cookie_password
# WorkOS webhook secret for signature verification (get from WorkOS dashboard)
WORKOS_WEBHOOK_SECRET=your_workos_webhook_secret

# PostHog Analytics (optional)
# Get these from your PostHog dashboard
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
# Use your region host; default US listed here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Vercel AI Gateway Configuration (optional)
# Provide to enable AI features in production/preview. Without keys, AI features may be limited.
VERCEL_AI_GATEWAY_API_KEY=
AI_GATEWAY_API_KEY=
# Supported models include:
#  - xai/grok-3-mini, xai/grok-beta
#  - google/gemini-2.0-flash-lite, google/gemini-1.5-pro
#  - openai/gpt-4o, openai/gpt-4o-mini, openai/gpt-3.5-turbo
#  - anthropic/claude-3.5-sonnet-20241022
#  - meta/llama-3.1-405b-instruct
AI_GATEWAY_MODEL=google/gemini-2.0-flash-lite
AI_GATEWAY_PROMPT="Tell me a joke"
AI_GATEWAY_JOKE_MEMORY_NUMBER=5

# Health/Readiness Feature (optional)
AI_GATEWAY_MODEL_HEALTH="xai/grok-3-mini"
# Note: AI prompt is now managed in TypeScript module (src/lib/ai-prompts/enhanced-health-advice.ts)
# No longer requires AI_GATEWAY_PROMPT_HEALTH environment variable

# Optional: AI Gateway Base URL override if needed
# AI_GATEWAY_BASE_URL=https://gateway.ai.vercel.com/v1

# Environment flags
# NEXT_PUBLIC_SITE_URL influences absolute URLs in the app.
# Local: http://localhost:3000
# Preview: https://<vercel-preview-url>
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# "development" | "preview" | "production"
NEXT_PUBLIC_ENV=development

# Node environment (build/runtime)
NODE_ENV=development

# Rate Limiting (handled by Convex functions)
# These values are used by Convex functions for rate limiting logic
RATE_LIMIT_ENABLED=true
RATE_LIMIT_TEMPLATE_OPERATIONS_PER_HOUR=1000
RATE_LIMIT_WORKOUT_OPERATIONS_PER_HOUR=1000
RATE_LIMIT_API_CALLS_PER_MINUTE=1000

# -------------------------------
# DEPLOYMENT ENVIRONMENTS
# -------------------------------

# DEVELOPMENT (Local .env.local):
# - CONVEX_DEPLOYMENT=dev:unique-deployment-name (auto-generated by `npx convex dev`)
# - NEXT_PUBLIC_SITE_URL=http://localhost:3000
# - NEXT_PUBLIC_ENV=development
# - Use test WorkOS keys (sk_test_*, client_*)
# - NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# PREVIEW (Vercel Preview Deployments):
# Set in Vercel Project Settings → Environment Variables (Target = Preview) or Infisical:
#   CONVEX_DEPLOYMENT=dev:your-development-deployment  # Can share dev deployment
#   NEXT_PUBLIC_CONVEX_URL=https://your-dev-deployment.convex.cloud
#   NEXT_PUBLIC_SITE_URL=https://<your-preview-url>
#   NEXT_PUBLIC_ENV=preview
#   WORKOS_API_KEY=sk_test_your_api_key
#   NEXT_PUBLIC_WORKOS_CLIENT_ID=client_your_client_id
#   NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://<your-preview-url>/callback
#   WORKOS_COOKIE_PASSWORD=your_32_character_password

# PRODUCTION (Vercel Production):
# Set in Vercel Project Settings → Environment Variables (Target = Production) or Infisical:
#   CONVEX_DEPLOYMENT=prod:your-production-deployment
#   NEXT_PUBLIC_CONVEX_URL=https://your-production-deployment.convex.cloud  
#   NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
#   NEXT_PUBLIC_ENV=production
#   NODE_ENV=production
#   WORKOS_API_KEY=sk_live_your_production_api_key
#   NEXT_PUBLIC_WORKOS_CLIENT_ID=client_your_production_client_id
#   NEXT_PUBLIC_WORKOS_REDIRECT_URI=https://your-production-domain.com/callback
#   WORKOS_COOKIE_PASSWORD=your_production_32_character_password

# INFISICAL INTEGRATION:
# - Install Infisical integration in your Vercel project
# - Manage environment variables in Infisical dashboard
# - Automatic sync to Vercel environments
# - Support for environment-specific overrides