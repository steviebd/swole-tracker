# ===========================================
# DATABASE CONFIGURATION
# ===========================================

# Primary database connection string
# For local development: Use your local PostgreSQL instance
# For production: Use your Supabase connection string
DATABASE_URL="postgresql://username:password@localhost:5432/swole_tracker"

# Supabase configuration (if using Supabase)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# ===========================================
# AUTHENTICATION (CLERK)
# ===========================================

# Clerk publishable key - Safe to expose in client-side code
# Format: pk_test_... or pk_live_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Clerk secret key - Keep this secret and secure
# Format: sk_test_... or sk_live_...
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Next.js URL configuration
# For local development
NEXTAUTH_URL="http://localhost:3000"

# Application environment
NODE_ENV="development"

# ===========================================
# PLAYWRIGHT TESTING CONFIGURATION
# ===========================================

# Base URL for Playwright tests
# For local testing: http://localhost:3000
# For production testing: https://your-app.vercel.app
PLAYWRIGHT_BASE_URL="http://localhost:3000"

# Test database (separate from main database)
# Use a dedicated test database to avoid data conflicts
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/swole_tracker_test"

# Production URL for E2E testing (GitHub Actions)
PLAYWRIGHT_PRODUCTION_URL="https://your-app.vercel.app"

# Test user credentials for Playwright authentication
# Create a dedicated test account in Clerk for this purpose
# The user MUST exist in your Clerk dashboard and have username/password authentication enabled
TEST_USER_EMAIL="test@example.com"
TEST_USER_PASSWORD="testpassword123"

# Alternative test identifiers (if using different strategies)
# For phone_code strategy: use a test phone number like +15555550100
# For email_code strategy: use a test email like your_email+clerk_test@example.com
TEST_USER_PHONE="+15555550100"
TEST_USER_EMAIL_CODE="your_email+clerk_test@example.com"

# ===========================================
# OPTIONAL INTEGRATIONS
# ===========================================

# PostHog Analytics (if enabled)
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# OpenAI API (if using AI features)
OPENAI_API_KEY="sk-your-openai-api-key"

# Google AI (if using Google AI features)
GOOGLE_AI_API_KEY="your-google-ai-api-key"

# ===========================================
# DEVELOPMENT TOOLS
# ===========================================

# Enable detailed logging in development
DEBUG="*"

# Disable telemetry for Next.js (optional)
NEXT_TELEMETRY_DISABLED="1"

# ===========================================
# SECURITY
# ===========================================

# JWT Secret for additional security (if needed)
JWT_SECRET="your-random-jwt-secret-key"

# Session secret for additional encryption
SESSION_SECRET="your-session-secret"

# ===========================================
# INSTRUCTIONS
# ===========================================

# 1. Copy this file to .env.local for local development
# 2. Replace all placeholder values with your actual credentials
# 3. Never commit actual credentials to version control
# 4. For production, set these variables in your hosting platform (Vercel, etc.)
# 5. For GitHub Actions, add sensitive variables as GitHub Secrets

# Required for basic functionality:
# - DATABASE_URL
# - NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
# - CLERK_SECRET_KEY

# Required for Playwright testing:
# - PLAYWRIGHT_BASE_URL
# - TEST_DATABASE_URL (for CI testing)
# - All Clerk variables

# Optional but recommended for production:
# - SUPABASE_URL and SUPABASE_ANON_KEY (if using Supabase)
# - PLAYWRIGHT_PRODUCTION_URL (for production E2E tests)
